# DevPilot external integration settings for an external project.
# Store these server-side only. Do not commit real secrets.

DEVPILOT_API_BASE_URL=https://devpilot.example.com
DEVPILOT_SOURCE_SYSTEM=your-source-system
DEVPILOT_API_KEY=paste-the-key-shown-once

# Stable project identity.
EXTERNAL_PROJECT_ID=your-project-prod
PROJECT_NAME=Your Project Name
ENVIRONMENT=production

# Optional project metadata.
LOCAL_PATH=E:\Ai-project\YourProject
NAS_WORKTREE_PATH=/volume1/worktrees/your-project
NAS_COMPOSE_PATH=/volume1/docker/your-project
NAS_DATA_PATH=/volume1/docker/your-project/data
REPO_URL=https://github.com/example/your-project
BRANCH=main
CONTAINER_NAME=your-project
COMPOSE_PROJECT=your-project
SERVICE_NAME=app
HOST_PORT=5015
CONTAINER_PORT=5000
APP_URL=https://your-project.example.com
PRIMARY_DOMAIN=your-project.example.com
REQUESTED_DOMAINS=your-project.example.com,www.your-project.example.com
DEPLOYMENT_TARGET=nas-docker
RUNTIME=docker
OWNER=team-or-owner
NOTES=Registered from project admin DevPilot integration
