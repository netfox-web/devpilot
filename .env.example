# DevPilot local development template
# Copy to .env for local development only. Do not commit real secrets.

API_TOKEN=
SECRET_KEY=
DEV_PILOT_API_URL=http://127.0.0.1:5000
DATABASE_PATH=data/project_manager.db
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent

# Cloudflare batch domain setup tool
# Use the minimum scoped token required for the approved operation.
# Leave blank unless a separately approved Cloudflare batch task requires it.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

DEFAULT_MAIN_TARGET=
DEFAULT_APP_TARGET=
DEFAULT_API_TARGET=

DEFAULT_PARKING_TARGET=aioffice.com.tw
DEFAULT_SSL_MODE=full
DEFAULT_PROXIED=true
